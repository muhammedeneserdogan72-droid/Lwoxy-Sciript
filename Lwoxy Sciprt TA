atApplyBtn.MouseButton1Click:Connect(function()
    local targetName = atNameBox.Text
    local cmd = atCmdBox.Text:lower()
    if targetName == "" then
        atStatus.Text = "Oyuncu ismi yaz!"
        atStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    if cmd == "" then
        atStatus.Text = "Komut yaz!"
        atStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end

    local targetPlayer = nil
    for _, plr in pairs(Players:GetPlayers()) do
        if plr.Name:lower() == targetName:lower() or plr.DisplayName:lower() == targetName:lower() then
            targetPlayer = plr
            break
        end
        if plr.Name:lower():find(targetName:lower()) or plr.DisplayName:lower():find(targetName:lower()) then
            targetPlayer = plr
        end
    end

    if not targetPlayer then
        atStatus.Text = "Oyuncu bulunamadi!"
        atStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        atStatus.Text = "Karakter yok!"
        atStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end

    local ch = LP.Character
    if not ch or not ch:FindFirstChild("HumanoidRootPart") or not ch:FindFirstChildOfClass("Humanoid") then
        atStatus.Text = "Senin karakterin yok!"
        atStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end

    local myHum = ch:FindFirstChildOfClass("Humanoid")
    followRunning = true
    atStatus.Text = "Uygulaniyor..."
    atStatus.TextColor3 = Color3.fromRGB(80, 255, 80)
    atApplyBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)

    task.spawn(function()
        if cmd:find("sola") then
            while followRunning do
                if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then break end
                if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then break end
                local tPos = targetPlayer.Character.HumanoidRootPart.Position
                local mPos = LP.Character.HumanoidRootPart.Position
                local dir = (mPos - tPos).Unit
                local angle = math.atan2(dir.X, dir.Z) - 0.15
                local newPos = tPos + Vector3.new(math.sin(angle) * 8, 0, math.cos(angle) * 8)
                LP.Character.HumanoidRootPart.CFrame = CFrame.new(newPos, tPos)
                atStatus.Text = "Sola Donuluyor..."
                task.wait(0.05)
            end
        elseif cmd:find("sag") then
            while followRunning do
                if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then break end
                if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then break end
                local tPos = targetPlayer.Character.HumanoidRootPart.Position
                local mPos = LP.Character.HumanoidRootPart.Position
                local dir = (mPos - tPos).Unit
                local angle = math.atan2(dir.X, dir.Z) + 0.15
                local newPos = tPos + Vector3.new(math.sin(angle) * 8, 0, math.cos(angle) * 8)
                LP.Character.HumanoidRootPart.CFrame = CFrame.new(newPos, tPos)
                atStatus.Text = "Saga Donuluyor..."
                task.wait(0.05)
            end
        elseif cmd:find("ileri") then
            while followRunning do
                if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then break end
                if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then break end
                myHum:MoveTo(targetPlayer.Character.HumanoidRootPart.Position)
                atStatus.Text = "Ileri gidiliyor..."
                task.wait(0.1)
            end
        elseif cmd:find("geri") then
            while followRunning do
                if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then break end
                if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then break end
                local tPos = targetPlayer.Character.HumanoidRootPart.Position
                local mPos = LP.Character.HumanoidRootPart.Position
                local dir = (mPos - tPos).Unit
                myHum:MoveTo(mPos + dir * 5)
                atStatus.Text = "Geri gidiliyor..."
                task.wait(0.1)
            end
        elseif cmd:find("dur") then
            followRunning = false
        else
            atStatus.Text = "Bilinmeyen komut!"
            atStatus.TextColor3 = Color3.fromRGB(255, 200, 0)
        end
        followRunning = false
        atStatus.Text = "Tamamlandi."
        atStatus.TextColor3 = Color3.fromRGB(150, 140, 140)
        atApplyBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    end)
end)

