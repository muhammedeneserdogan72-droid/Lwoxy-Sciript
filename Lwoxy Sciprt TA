local function switchCat(name)
    curCat = name
    for n, d in pairs(catBtns) do
        if n == name then
            d.bar.Visible = true
            TS:Create(d.btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 6, 6), BackgroundTransparency = 0.3}):Play()
            TS:Create(d.lbl, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(255, 80, 80)}):Play()
        else
            d.bar.Visible = false
            TS:Create(d.btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(16, 14, 14), BackgroundTransparency = 0.5}):Play()
            TS:Create(d.lbl, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(150, 140, 140)}):Play()
        end
    end
    for n, p in pairs(Pages) do
        p.Visible = (n == name)
    end
end

