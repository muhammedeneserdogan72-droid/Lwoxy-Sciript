-- Turkce sayi cevirme
local turkSayi = {
    [0]="Sifir",[1]="Bir",[2]="Iki",[3]="Uc",[4]="Dort",
    [5]="Bes",[6]="Alti",[7]="Yedi",[8]="Sekiz",[9]="Dokuz",
    [10]="On",[11]="On Bir",[12]="On Iki",[13]="On Uc",[14]="On Dort",
    [15]="On Bes",[16]="On Alti",[17]="On Yedi",[18]="On Sekiz",[19]="On Dokuz",
    [20]="Yirmi",[30]="Otuz",[40]="Kirk",[50]="Elli",
    [60]="Altmis",[70]="Yetmis",[80]="Seksen",[90]="Doksan"
}

local function sayiyiYaz(n)
    if n < 0 then return "Eksi " .. sayiyiYaz(-n) end
    if n <= 19 then return turkSayi[n] or tostring(n) end
    if n < 100 then
        local onlar = math.floor(n / 10) * 10
        local birler = n % 10
        if birler == 0 then return turkSayi[onlar] end
        return turkSayi[onlar] .. " " .. turkSayi[birler]
    end
    if n < 1000 then
        local yuzler = math.floor(n / 100)
        local kalan = n % 100
        local s = ""
        if yuzler == 1 then s = "Yuz" else s = turkSayi[yuzler] .. " Yuz" end
        if kalan > 0 then s = s .. " " .. sayiyiYaz(kalan) end
        return s
    end
    if n < 1000000 then
        local binler = math.floor(n / 1000)
        local kalan = n % 1000
        local s = ""
        if binler == 1 then s = "Bin" else s = sayiyiYaz(binler) .. " Bin" end
        if kalan > 0 then s = s .. " " .. sayiyiYaz(kalan) end
        return s
    end
    return tostring(n)
end

